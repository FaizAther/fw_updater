            "type": "shell",
            "command": "make flash",
            "dependsOn": "Build",
            "problemMatcher": []
        },
        {
            "label": "Flash (st-flash)",
            "type": "shell",
            "command": "make flash-stlink",
            "dependsOn": "Build",
            "problemMatcher": []
        }
    ]
}
